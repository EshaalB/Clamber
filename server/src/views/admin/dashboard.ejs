<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clamber Admin — Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 240px; background: #1e293b; padding: 24px 16px; border-right: 1px solid #334155; }
    .logo { display: flex; align-items: center; gap: 10px; font-size: 20px; font-weight: 800; margin-bottom: 40px; padding: 0 8px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: 10px; color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s; margin-bottom: 4px; }
    .nav-item:hover, .nav-item.active { background: #334155; color: #e2e8f0; }
    .main { flex: 1; padding: 32px; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    h1 { font-size: 28px; font-weight: 800; }
    .btn-logout { padding: 10px 20px; background: #334155; border: none; border-radius: 8px; color: #94a3b8; cursor: pointer; font-size: 13px; text-decoration: none; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: #1e293b; padding: 24px; border-radius: 14px; border: 1px solid #334155; }
    .stat-label { font-size: 13px; color: #94a3b8; margin-bottom: 8px; }
    .stat-value { font-size: 32px; font-weight: 800; }
    .stat-value.blue { color: #7cb9e8; }
    .stat-value.green { color: #98d4bb; }
    .stat-value.peach { color: #f5b89a; }
    .stat-value.lavender { color: #b4a7d6; }
    .section { background: #1e293b; border-radius: 14px; padding: 24px; border: 1px solid #334155; }
    .section h3 { font-size: 16px; margin-bottom: 16px; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 12px; color: #64748b; padding: 10px 12px; border-bottom: 1px solid #334155; text-transform: uppercase; letter-spacing: 0.5px; }
    td { padding: 12px; font-size: 14px; border-bottom: 1px solid #1e293b; }
    tr:hover td { background: #334155; }
    .badge { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; }
    .badge-verified { background: #98d4bb20; color: #98d4bb; }
    .badge-unverified { background: #f5b89a20; color: #f5b89a; }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7cb9e8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 2 15H2L8 3z"/></svg>
        Clamber
      </div>
      <a href="/admin/dashboard" class="nav-item active">📊 Dashboard</a>
      <a href="/admin/users" class="nav-item">👥 Users</a>
      <a href="/admin/tasks" class="nav-item">✅ Tasks</a>
      <a href="/admin/courses" class="nav-item">🎓 Courses</a>
      <a href="/admin/feedback" class="nav-item">💬 Feedback</a>
      <a href="/admin/logs" class="nav-item">📋 System Logs</a>
      <a href="/admin/logout" class="nav-item" style="margin-top: auto; color: #ef4444;">🚪 Logout</a>
    </aside>

    <main class="main">
      <div class="header">
        <h1>Dashboard Overview</h1>
        <a href="/admin/logout" class="btn-logout">Logout</a>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Total Users</div>
          <div class="stat-value blue"><%= stats.totalUsers %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Total Tasks</div>
          <div class="stat-value green"><%= stats.totalTasks %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Active Sessions</div>
          <div class="stat-value peach"><%= stats.activeSessions %></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Feedback</div>
          <div class="stat-value lavender"><%= stats.totalFeedback %></div>
        </div>
      </div>

      <div class="section">
        <h3>Recent Users</h3>
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Status</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% recentUsers.forEach(u => { %>
              <tr>
                <td><%= u.name %></td>
                <td style="color: #94a3b8;"><%= u.email %></td>
                <td><span class="badge <%= u.isVerified ? 'badge-verified' : 'badge-unverified' %>"><%= u.isVerified ? 'Verified' : 'Unverified' %></span></td>
                <td style="color: #64748b;"><%= new Date(u.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>
</body>
</html>
