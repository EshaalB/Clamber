<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Clamber Admin — Courses</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f172a; color: #e2e8f0; }
    .layout { display: flex; min-height: 100vh; }
    .sidebar { width: 240px; background: #1e293b; padding: 24px 16px; border-right: 1px solid #334155; }
    .logo { display: flex; align-items: center; gap: 10px; font-size: 20px; font-weight: 800; margin-bottom: 40px; padding: 0 8px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-radius: 10px; color: #94a3b8; text-decoration: none; font-size: 14px; font-weight: 500; margin-bottom: 4px; }
    .nav-item:hover, .nav-item.active { background: #334155; color: #e2e8f0; }
    .main { flex: 1; padding: 32px; }
    .header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    h1 { font-size: 28px; font-weight: 800; }
    .btn-add { padding: 10px 20px; background: #f59e0b; border: none; border-radius: 8px; color: white; font-weight: 600; cursor: pointer; }
    .search-bar { display: flex; gap: 12px; margin-bottom: 24px; }
    .search-bar input { flex: 1; padding: 12px 16px; background: #1e293b; border: 1px solid #334155; border-radius: 10px; color: #e2e8f0; font-size: 14px; outline: none; }
    .search-bar button { padding: 12px 24px; background: #334155; border: 1px solid #334155; border-radius: 10px; color: white; font-weight: 600; cursor: pointer; }
    .section { background: #1e293b; border-radius: 14px; padding: 24px; border: 1px solid #334155; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; font-size: 12px; color: #64748b; padding: 10px 12px; border-bottom: 1px solid #334155; text-transform: uppercase; }
    td { padding: 12px; font-size: 14px; border-bottom: 1px solid #1e293b44; }
    tr:hover td { background: #334155; }
    .badge { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 600; }
    .badge-on-track { background: #10b98120; color: #10b981; }
    .badge-at-risk { background: #ef444420; color: #ef4444; }
    .actions { display: flex; gap: 8px; }
    .btn-edit { color: #3b82f6; background: none; border: none; cursor: pointer; font-size: 12px; font-weight: 600; }
    .btn-delete { color: #ef4444; background: none; border: none; cursor: pointer; font-size: 12px; font-weight: 600; }
    
    .modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); align-items: center; justify-content: center; z-index: 100; }
    .modal.active { display: flex; }
    .modal-content { background: #1e293b; border: 1px solid #334155; padding: 32px; border-radius: 16px; width: 450px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 12px; color: #94a3b8; margin-bottom: 8px; }
    .form-group input, .form-group select { width: 100%; padding: 10px; background: #0f172a; border: 1px solid #334155; border-radius: 8px; color: #fff; outline: none; }
    .form-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; }
    .btn-cancel { padding: 10px 16px; background: #334155; color: #fff; border: none; border-radius: 8px; cursor: pointer; }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#7cb9e8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 2 15H2L8 3z"/></svg>
        Clamber
      </div>
      <a href="/admin/dashboard" class="nav-item">📊 Dashboard</a>
      <a href="/admin/users" class="nav-item">👥 Users</a>
      <a href="/admin/tasks" class="nav-item">✅ Tasks</a>
      <a href="/admin/courses" class="nav-item active">🎓 Courses</a>
      <a href="/admin/feedback" class="nav-item">💬 Feedback</a>
      <a href="/admin/logs" class="nav-item">📋 System Logs</a>
      <a href="/admin/logout" class="nav-item" style="color: #ef4444;">🚪 Logout</a>
    </aside>

    <main class="main">
      <div class="header-row">
        <h1>Course Management</h1>
        <button class="btn-add" onclick="showAddModal()">+ Add Course</button>
      </div>

      <form class="search-bar" method="GET" action="/admin/courses">
        <input type="text" name="search" placeholder="Search courses by name..." value="<%= search %>">
        <button type="submit">Search</button>
      </form>

      <div class="section">
        <table>
          <thead><tr><th>User</th><th>Name</th><th>Credits</th><th>Grade</th><th>Status</th><th>Assessments</th><th>Actions</th></tr></thead>
          <tbody>
            <% courses.forEach(c => { %>
              <tr>
                <td><%= c.userId ? c.userId.name : 'Unknown' %></td>
                <td><%= c.name %></td>
                <td><%= c.credits %></td>
                <td><%= c.currentGrade %>% / Target: <%= c.targetGrade %>%</td>
                <td><span class="badge badge-<%= c.status.toLowerCase().replace(' ', '-') %>"><%= c.status %></span></td>
                <td><%= c.assessments ? c.assessments.length : 0 %> items</td>
                <td class="actions">
                  <button class="btn-edit" onclick="showEditModal('<%= JSON.stringify(c) %>')">Edit</button>
                  <form action="/admin/courses/<%= c._id %>/delete" method="POST" onsubmit="return confirm('Delete course?')">
                    <button type="submit" class="btn-delete">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </div>

  <!-- Add Course Modal -->
  <div id="addModal" class="modal">
    <div class="modal-content">
      <h2>Add New Course</h2>
      <form action="/admin/courses" method="POST">
        <div class="form-group">
          <label>Assign to User</label>
          <select name="userId" required>
            <% users.forEach(u => { %>
              <option value="<%= u._id %>"><%= u.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Course Name</label>
          <input type="text" name="name" required>
        </div>
        <div class="form-group">
          <label>Credits</label>
          <input type="number" name="credits" min="1" max="6" value="3" required>
        </div>
        <div class="form-group">
          <label>Target Grade (%)</label>
          <input type="number" name="targetGrade" min="0" max="100" value="80" required>
        </div>
        <div class="form-actions">
          <button type="button" class="btn-cancel" onclick="hideModals()">Cancel</button>
          <button type="submit" class="btn-add">Create Course</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Course Modal -->
  <div id="editModal" class="modal">
    <div class="modal-content">
      <h2>Edit Course</h2>
      <form id="editForm" action="" method="POST">
        <div class="form-group">
          <label>Course Name</label>
          <input type="text" name="name" id="editName" required>
        </div>
        <div class="form-group">
          <label>Credits</label>
          <input type="number" name="credits" id="editCredits" min="1" max="6" required>
        </div>
        <div class="form-group">
          <label>Current Grade (%)</label>
          <input type="number" name="currentGrade" id="editGrade" min="0" max="100" required>
        </div>
        <div class="form-group">
          <label>Target Grade (%)</label>
          <input type="number" name="targetGrade" id="editTarget" min="0" max="100" required>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status" id="editStatus">
            <option value="On Track">On Track</option>
            <option value="Slight Risk">Slight Risk</option>
            <option value="At Risk">At Risk</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="button" class="btn-cancel" onclick="hideModals()">Cancel</button>
          <button type="submit" class="btn-add" style="background: #3b82f6;">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function showAddModal() { document.getElementById('addModal').classList.add('active'); }
    function hideModals() { 
      document.getElementById('addModal').classList.remove('active'); 
      document.getElementById('editModal').classList.remove('active'); 
    }
    function showEditModal(courseStr) {
      const course = JSON.parse(courseStr);
      const form = document.getElementById('editForm');
      form.action = `/admin/courses/${course._id}`;
      document.getElementById('editName').value = course.name;
      document.getElementById('editCredits').value = course.credits;
      document.getElementById('editGrade').value = course.currentGrade;
      document.getElementById('editTarget').value = course.targetGrade;
      document.getElementById('editStatus').value = course.status;
      document.getElementById('editModal').classList.add('active');
    }
  </script>
</body>
</html>
